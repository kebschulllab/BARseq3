def save_hdf5(matrix, file_path): #assumes this is a list of np arrays
    f = h5py.File(file_path,'w')
    grp = f.create_group('list')
    for i,arr in enumerate(matrix):
        grp.create_dataset(str(i), data=arr)
    f.close()
    return None





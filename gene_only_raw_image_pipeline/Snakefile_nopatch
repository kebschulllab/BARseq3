        print(datetime.now().strftime("%d/%m/%Y %H:%M:%S"), "        "+'    thresh: '+str(thresh)+'; fdrmean: '+str(fdrmean)+'; diff:'+str(diff))
        thresh -= stepsize * diff / abs(diff)
        stepsize /= 2
    thresh_refined = thresh_list[-1]
